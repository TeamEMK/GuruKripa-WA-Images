# Copy to .env and fill in. Do NOT commit the real .env (it is gitignored).

# ── WhatsApp (aumpfy gateway) ──────────────────────────────
WA_API_KEY=
WA_API_URL=                     # endpoint aumpfy uses to send an image
WA_TEXT_API_URL=                # endpoint aumpfy uses to send a text reply
WA_IMAGES_GROUP_ID=             # optional: only react to this group (image matcher)
WEBHOOK_SECRET=                 # HMAC secret for the /webhook signature

# ── Google Drive (service account, read-only) ──────────────
DRIVE_FOLDER_ID=                # root folder to index (scans nested subfolders)
GOOGLE_CREDENTIALS_PATH=credentials.json
# On Railway, leave the file out and provide the JSON as base64 instead:
GOOGLE_CREDENTIALS_BASE64=      # base64 of the service-account JSON (optional, Railway)

# ── Server ─────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000   # public base URL; used to build outgoing image links

# ── Security ───────────────────────────────────────────────
ADMIN_API_KEY=                  # if set, mutating /admin + /ims routes require X-Admin-Key header
ALLOWED_ORIGINS=*               # comma-separated CORS origins, e.g. https://your-app.vercel.app
MEDIA_ALLOWED_HOSTS=            # comma-separated hostnames allowed for media download (empty → derived from WA_API_URL)

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=
VISION_MODEL=gpt-4.1                 # image profiling + query analysis
EMBEDDING_MODEL=text-embedding-3-large   # 3072-d unified image/text vectors
MIN_MATCH_SCORE=0.0                  # drop semantic matches below this cosine score (0 = keep all)
AUTO_INDEX_INTERVAL_MINUTES=10       # auto-scan Drive for NEW images every N min (0 = off)

# ── Guru Kripa (WhatsApp group bot) ────────────────────────
GURU_KRIPA_GROUP_ID=            # only react to this group
GURU_KRIPA_WEBHOOK_SECRET=      # HMAC secret for /guru-kripa/webhook
